{
  "name": "@pos-system/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "exports": { "./routes": "./src/routes/index.ts" },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint .",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pos-system-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pos-system-db --remote"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.4",
    "@scalar/hono-api-reference": "^0.9.24",
    "@pos-system/eslint-config": "workspace:^",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.10.4",
    "hono-pino": "^0.10.3",
    "jose": "^5.10.0",
    "pino": "^10.1.0",
    "stoker": "^2.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.5",
    "@cloudflare/workers-types": "^4.20251106.1",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.54.0"
  }
}
