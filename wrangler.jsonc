{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pos-system",
  "account_id": "REPLACE_ACCOUNT_ID",
  "main": "apps/api/src/app.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [{ "pattern": "REPLACE_DOMAIN", "custom_domain": true }],
  "assets": { "directory": "apps/web/dist", "binding": "ASSETS" },
  "vars": {
    "APP_URL": "https://REPLACE_DOMAIN",
    "LOG_LEVEL": "info",
    "NODE_ENV": "production"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pos-system-db",
      "database_id": "REPLACE_DB_ID",
      "migrations_dir": "apps/api/src/db/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "STORAGE",
      "bucket_name": "pos-system-storage"
    }
  ]
}
